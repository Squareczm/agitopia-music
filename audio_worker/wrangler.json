{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "music-audio",
  "main": "index.js",
  "compatibility_date": "2024-12-01",
  "workers_dev": true,
  "r2_buckets": [
    {
      "bucket_name": "ainovalife-music",
      "binding": "ainovalife_music"
    }
  ],
  "routes": [
    { "pattern": "audio.ainovalife.com", "custom_domain": true }
  ]
}
